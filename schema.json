{
    "sync_interval_sec": {
        "type": "integer",
        "default": 1800,
        "hint": "同步间隔（秒，最小 60 秒）"
    },
    "download_concurrency": {
        "type": "integer",
        "default": 5,
        "hint": "下载并发数（最小 1）"
    },
    "vlm_concurrency": {
        "type": "integer",
        "default": 3,
        "hint": "VLM 描述并发数（控制同时调用 VLM 的上限，最小 1）"
    },
    "vlm_compress_enabled": {
        "type": "switch",
        "default": false,
        "hint": "VLM 描述前将图片转为 JPEG 有损压缩，减小 payload"
    },
    "vlm_compress_quality": {
        "type": "integer",
        "default": 85,
        "hint": "JPEG 压缩质量 (10-100)"
    },
    "auto_delete": {
        "type": "switch",
        "default": false,
        "hint": "自动删除 QQ 收藏中已取消的表情"
    }
}
