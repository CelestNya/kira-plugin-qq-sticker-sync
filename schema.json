{
    "sync_interval_sec": {
        "type": "integer",
        "default": 1800,
        "hint": "同步间隔（秒，最小 60 秒）"
    },
    "download_concurrency": {
        "type": "integer",
        "default": 5,
        "hint": "下载并发数（最小 1）"
    },
    "register_concurrency": {
        "type": "integer",
        "default": 3,
        "hint": "注册并发数（控制触发 VLM 描述的并发上限，最小 1）"
    },
    "auto_delete": {
        "type": "switch",
        "default": false,
        "hint": "自动删除 QQ 收藏中已取消的表情"
    }
}
